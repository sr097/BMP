# Groq API Key for AI responses
# Get your API key from https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# API Server Port
PORT=8080

# Frontend API URL (for production deployments)
# VITE_API_URL=https://your-api-domain.com

# Database URL (optional - app works with in-memory storage for development)
# PostgreSQL connection string for production
# DATABASE_URL=postgresql://user:password@localhost:5432/clearspeak

# OIDC Configuration (optional - for Replit authentication)
# ISSUER_URL=https://replit.com/oidc
# REPL_ID=your_repl_id

# CORS Origins (optional - defaults to localhost:3000 and localhost:5173)
# CORS_ORIGIN=http://localhost:3000,http://localhost:5173